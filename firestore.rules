rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definitions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    // 2. Entity Validations
    function isValidMeme(data) {
      return data.keys().hasAll(['authorId', 'createdAt', 'objects']) &&
             data.keys().size() <= 4 &&
             data.authorId is string &&
             data.authorId == request.auth.uid &&
             data.createdAt is string &&
             data.createdAt.size() <= 50 &&
             data.objects is list &&
             data.objects.size() <= 100 &&
             (data.keys().hasAny(['templateUrl']) ? (data.templateUrl is string && data.templateUrl.size() <= 2000) || data.templateUrl == null : true);
    }
    
    function isValidMemeUpdate(data) {
      return data.keys().hasAll(['authorId', 'createdAt', 'objects']) &&
             data.keys().size() <= 4 &&
             data.authorId is string &&
             data.authorId == existing().authorId &&
             data.createdAt is string &&
             data.createdAt == existing().createdAt &&
             data.objects is list &&
             data.objects.size() <= 100 &&
             (data.keys().hasAny(['templateUrl']) ? (data.templateUrl is string && data.templateUrl.size() <= 2000) || data.templateUrl == null : true);
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'templateId', 'url', 'name', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.userId is string &&
             data.userId == request.auth.uid &&
             data.templateId is string &&
             data.templateId.size() <= 128 &&
             data.url is string &&
             data.url.size() <= 2000 &&
             data.name is string &&
             data.name.size() <= 200 &&
             data.createdAt is string &&
             data.createdAt.size() <= 50;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['userId', 'userName', 'memeUrl', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.userId is string &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.userName.size() <= 100 &&
             data.memeUrl is string &&
             data.memeUrl.size() <= 20000 &&
             data.createdAt is string &&
             data.createdAt.size() <= 50;
    }

    // 3. Collection Rules
    match /memes/{memeId} {
      // Anyone can read a meme (for sharing)
      allow get: if isValidId(memeId);
      // Only author can list their own
      allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(memeId) && isValidMeme(incoming());
      
      allow update: if isSignedIn() && isValidId(memeId) && existing().authorId == request.auth.uid && isValidMemeUpdate(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['objects', 'templateUrl'])
      );
      
      allow delete: if isSignedIn() && isValidId(memeId) && existing().authorId == request.auth.uid;
    }
    
    // Favorites rules
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && isValidId(favoriteId) && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(favoriteId) && isValidFavorite(incoming());
      allow update: if false; // Favorites shouldn't be updated, just created or deleted
      allow delete: if isSignedIn() && isValidId(favoriteId) && existing().userId == request.auth.uid;
    }

    function isValidCustomTemplate(data) {
      return data.keys().hasAll(['userId', 'userName', 'url', 'name', 'width', 'height', 'box_count', 'createdAt']) &&
             data.userId is string &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.url is string &&
             data.url.size() <= 100000 &&
             data.name is string &&
             data.width is number &&
             data.height is number &&
             data.box_count is number &&
             data.createdAt is string;
    }

    match /templates/{templateId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidCustomTemplate(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidCustomTemplate(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    function isValidTemplateVote(data) {
      return data.keys().hasAll(['upvoters', 'downvoters']) &&
             data.upvoters is list &&
             data.downvoters is list;
    }

    match /templateVotes/{templateId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidTemplateVote(incoming());
      allow update: if isSignedIn() && isValidTemplateVote(incoming());
      allow delete: if false;
    }

    match /submissions/{submissionId} {
      // List/read only allowed for own submissions to prevent data exposure (OWASP Broken Access Control)
      allow read: if isSignedIn() && isValidId(submissionId) && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(submissionId) && isValidSubmission(incoming());
      allow update: if false; // Submissions are immutable
      allow delete: if isSignedIn() && isValidId(submissionId) && existing().userId == request.auth.uid;
    }
  }
}
